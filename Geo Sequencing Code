from scipy.optimize import linear_sum_assignment

def sequence_recommender(piv_table, page, device, section):
  profit_matrix = piv_table.values.tolist()
  for i in range(0,len(profit_matrix)):
      profit_matrix[i]=pd.to_numeric(piv_table.values.tolist()[i])
  
  max_value = np.max(profit_matrix)
  #Using the cost matrix to find which positions are the answer
  cost_matrix = max_value - profit_matrix
  row_ind, col_ind = linear_sum_assignment(cost_matrix)
  # print(col_ind)
  # display(piv_table)
  
  ranks = col_ind
  #Impact analysis
  #     target_impressions = np.array(impressions['IMPRESSIONS'])
  #     target_cconv = np.array(cConv['CCONV']).astype(float)
  #     print(f'target impressions: {target_impressions}')
  #     print(f'target cConv: {target_cconv}')
  
  a=piv_table
  a.index = a.index.astype(float)
  # display(piv_table)
  #     output = {}
  ordinals = []
  products_in_order=[]
  #Using the avg CCONV
  for i in range(0,len(ranks)):
      # print(f'{a.columns[ranks[i]]} at {i+1}')
      ordinals.append(i+1)
      products_in_order.append(a.columns[ranks[i]])
  #         output[position]=a.columns[ranks[i]]
  
  
  recommended_sequence = []
  recommended_sequence_details = []
  for index, row in piv_table.iterrows():
    try:
      #drop any already sequenced products from being considered in the next sequence
      if len(recommended_sequence) > 0:
        for element in recommended_sequence:
          row.pop(element)
      # display(row)
      #Find the product with the highest ARPI in the row
      selected_product = row.idxmax()
      #Add the product to our recommended sequence list
      recommended_sequence.append(selected_product)
      recommended_sequence_details.append(
                   {
                      'URL_PATH_TX': page,
                      'DEVICE_TYPE_NM': device,
                      'SECTION_NM': section,
                      'PRODUCT_NM': selected_product,
                      'PRODUCT_RANK':index,
                      'ARPI':max(row)
                   }
                )
    except:
      break
  
  # print(recommended_sequence)
  sequence = pd.DataFrame(recommended_sequence_details)
  
  return sequence

