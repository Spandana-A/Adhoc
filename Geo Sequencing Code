-- Declaring time period variables
SET (start_date, end_date)= ('2024-05-01',CURRENT_DATE() );

WITH CC_PRODUCTS AS (
    SELECT DISTINCT PRODUCT_NM 
      , OFFER_ID 
      , MARKETPLACE_ID 
      , PRODUCT_ID 
      , INSTITUTION_NM
    FROM NEXUS.PROD.D_MARKETPLACE 
    WHERE PRODUCT_TYPE_NM = 'credit_cards'
      AND ACTIVE_IN=TRUE 
      AND CURR_IN=TRUE
      AND MARKETPLACE_MONETIZING_IN=TRUE
    ORDER BY 1
  ),
  
ctr_1 AS (
  SELECT DISTINCT dv.pageview_dt as dw_eff_dt
    , REPLACE(dv.pageview_url_path, '/best/credit-cards','best/credit-cards') AS URL_PATH_TX 
    , FA.IMPRESSION_SECTION AS SECTION_NM
    , FA.DEVICE_TYPE AS DEVICE_TYPE_NM
    , FA.SKU_ID AS MARKETPLACE_OFFER_ID
    , (FA.IMPRESSION_POSITION + 1) PRODUCT_RANK
    , COUNT(DISTINCT FA.SKU_IMPRESSION_ID) AS IMPRESSION_CT
    , COUNT(DISTINCT FA2.SHOPPING_FINISH_ID) AS MCLICK_CT
  FROM NEXUS.PROD.F_PAGEVIEW as dv
  JOIN NEXUS.PROD.F_SKU_IMPRESSION FA
    ON FA.IMPRESSION_PAGEVIEW_ID = DV.PAGEVIEW_ID
        AND FA.SKU_IMPRESSION_DT BETWEEN $start_date and $end_date
  LEFT JOIN NEXUS.PROD.F_SHOPPING_FINISH FA2 
    ON FA.SKU_IMPRESSION_ID=FA2.SKU_IMPRESSION_ID
        AND FA2.SKU_PRODUCT_TYPE ILIKE '%credit_cards%'
        AND FA2.VERTICAL_NAME ILIKE '%Credit Cards%'
  WHERE URL_PATH_TX ILIKE '%best/credit-cards/%'
    AND DV.PAGEVIEW_DT BETWEEN $start_date and $end_date
    AND FA.MONETIZABLE = 'yes_assumed'
    AND FA.VERTICAL_NAME ILIKE '%Credit Cards%'
    AND FA.SKU_PRODUCT_TYPE ILIKE '%credit_cards%'
    AND FA.DEVICE_TYPE IN ('desktop','mobile')
   GROUP BY 1,2,3,4,5,6
   HAVING IMPRESSION_CT >10
  ),

  dealing_with_significant_offer_changes as (
select * 
, case when marketplace_offer_id = '2335a130-28eb-4df3-9129-4194f1aeec2f' and dw_eff_dt < '2023-11-14' then 0 -- the date the significant change to the BankAmericard offer was made
else 1
end as valid_data
from ctr_1
where valid_data = 1
),

product_agnostic_CTRs AS (
select url_path_Tx
    , section_nm
    , device_type_nm
    -- , marketplace_offer_id
    , product_rank
    , sum(impression_ct) as impressions
    , sum(mclick_ct) as mclicks
from dealing_with_significant_offer_changes
where valid_data = 1
group by 1,2,3,4
)

SELECT URL_PATH_TX
    , DEVICE_TYPE_NM
    , SECTION_nm
    , PRODUCT_RANK 
    , SUM(IMPRESSIONS) AS PRODUCT_AGNOSTIC_IMPRESSIONS
    , SUM(MCLICKS) AS PRODUCT_AGNOSTIC_MCLICKS
    -- , COUNT(DISTINCT MARKETPLACE_OFFER_ID) AS DISTINCT_PRODUCTS_CONTRIBUTING_TO_CTR
    , DIV0(PRODUCT_AGNOSTIC_MCLICKS, PRODUCT_AGNOSTIC_IMPRESSIONS) AS PRODUCT_AGNOSTIC_CTR
FROM ( 
    SELECT * FROM product_agnostic_CTRs  
