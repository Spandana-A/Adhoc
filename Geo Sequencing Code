SET (target_date_start, target_date_end)= (CURRENT_DATE()-30, CURRENT_DATE() );
SET (start_date, end_date)= ('2024-05-01', current_date()-1);

with click_ids AS (

  select SHOPPING_FINISH_DT as CLICK_DATE
    , REPLACE(fa2.IMPRESSION_PAGE_URL,'https://www.nerdwallet.com/','') as URL_PATH_TX
    , fa1.DEVICE_TYPE AS DEVICE_TYPE_NM
    , fa2.IMPRESSION_SECTION AS SECTION_NM
    , fa2.SKU_ID AS MARKETPLACE_OFFER_ID
    , SHOPPING_FINISH_ID
 from NEXUS.PROD.F_SHOPPING_FINISH FA2
 left join NEXUS.PROD.F_SKU_IMPRESSION fa1
  on fa2.SKU_IMPRESSION_ID = fa1.SKU_IMPRESSION_ID
 where URL_PATH_TX  ILIKE '%best/credit-cards/%'
 and fa2.MONETIZABLE = 'yes_assumed'
 and SECTION_NM in ('roundup_summary_table','roundup_recommendations')
 and fa2.SHOPPING_FINISH_DT between $start_date and $end_date
 and fa1.device_type in ('desktop','mobile')
  ),


  
txn_ids as (
select click_ids.*
, fa3.TRANSACTION_ID as txn_id
, fa3.revenue_ingested as commission
, fa3.TRANSACTION_COUNT 
from click_ids
left join nexus.prod.f_affiliate_transaction fa3
    on click_ids.shopping_finish_id = fa3.shopping_finish_id
    and fa3.revenue_ingested > 0 
    and fa3.TRANSACTION_DATE >= $start_date
    AND FA3.REVENUE_TRANSACTION_IN = TRUE
),


recent_cConv as (
select click_date 
    , url_path_Tx
    , device_type_nm
    , section_nm
    , marketplace_offer_id
    , MKT.PRODUCT_NM
    , count(distinct shopping_finish_id) as mClicks
    , COALESCE(sum(transaction_count),0) as txns
    -- , count(distinct txn_id) as txns
    , sum(commission) as commission
    , div0(txns, mclicks) as cConv
    -- , div0(transactions, mclicks) as cConv_2
from txn_ids
LEFT JOIN NEXUS.PROD.D_MARKETPLACE mkt
ON txn_ids.MARKETPLACE_OFFER_ID=MKT.OFFER_ID 
  AND MKT.CURR_IN=TRUE
//  AND MKT.ACTIVE_IN=TRUE
group by 1,2,3,4,5,6
),


cConv_0 as (
select * from recent_cconv
UNION
select * from  cards_mart_workspace.pbansal.cc_pulkit_sequencing_historical_cconv
  -- where url_path_tx not in ('best/credit-cards/zero-percent','best/credit-cards/no-annual-fee','best/credit-cards/bad-credit','best/credit-cards/no-credit', 'best/credit-cards/no-foreign-transaction-fee')
),

CCONV AS (
select cConv_0.*
  , mkt.PRODUCT_ID
  , case when cConv_0.marketplace_offer_id = '2335a130-28eb-4df3-9129-4194f1aeec2f' and click_date < '2023-11-14' then 0 -- the date the significant change to the BankAmericard offer was made
     when cconv_0.marketplace_offer_id = '4528cd20-add2-11eb-b8c6-230f8597051d' then 0 -- exlucde Apple
     when click_date between '2024-07-24' and '2024-08-01' then 0 -- data issue.
     when url_path_tx in ('best/credit-cards/zero-percent','best/credit-cards/no-annual-fee','best/credit-cards/bad-credit','best/credit-cards/no-credit', 'best/credit-cards/no-foreign-transaction-fee')
         and click_date < current_date()-180 then 0
      else 1
      end as valid_data
from cConv_0
LEFT JOIN NEXUS.PROD.D_MARKETPLACE mkt
ON cConv_0.MARKETPLACE_OFFER_ID=MKT.OFFER_ID 
  AND MKT.CURR_IN=TRUE
where url_path_tx in ('best/credit-cards/balance-transfer','best/credit-cards/cash-back','best/credit-cards/bonus-offers',
                      'best/credit-cards/low-interest','best/credit-cards/rewards','best/credit-cards/travel', 'best/credit-cards/no-foreign-transaction-fee',
                      'best/credit-cards/airline', 'best/credit-cards/groceries', 'best/credit-cards/gas','best/credit-cards/american-express-cards',
                      'best/credit-cards/zero-percent','best/credit-cards/no-annual-fee','best/credit-cards/bad-credit','best/credit-cards/no-credit'
                      )
  and valid_data = 1
order by 1 desc
),


T1 AS (
      SELECT
      date(dw_eff_dt) as DW_EFF_DT,
      DAYNAME(DW_EFF_DT) AS DAY,
      CASE WHEN DATEDIFF(day,DW_EFF_DT,current_date())<=20 then 1 else 0 end as within_outlier_calc_period,
      'Credit Cards' AS vertical,
      aflt_partner_nm,
      MARKETPLACE_PROD_ID,
      sum(TXN_CNT) AS ALL_TXNS, -- ALL TXNS (NON - PFP INCLUDED)
      SUM(ingested_txn_cnt) AS REV_TXNS, -- PFP ACCOUNTED TXNS
      SUM(ingested_commission_am) AS revenue
      FROM "PROD_ETL"."ATARI_FORKLIFT"."IMPACT_NEW_CAPITAL_ONE_CREDIT_CARDS"
      WHERE DW_EFF_DT >= $target_date_start
      and DW_EFF_DT <= $target_date_end
      AND ingested_revenue_tran_in = TRUE
      AND (lower(category) not ilike '%spark%' OR lower(category) IS NULL)
      GROUP BY 1,2,3,4,5,6

      UNION ALL

      SELECT
      date(dw_eff_dt) as DW_EFF_DT,
      DAYNAME(DW_EFF_DT) AS DAY,
      CASE WHEN DATEDIFF(day,DW_EFF_DT,current_date())<=20 then 1 else 0 end as within_outlier_calc_period,
      'Credit Cards' AS vertical,
      aflt_partner_nm,
      MARKETPLACE_PROD_ID,
      sum(TXN_CT) AS ALL_TXNS, -- SAME AS INGESTED TXNS FOR NON-CAPONE PRODUCTS
      SUM(txn_ct) AS REV_TXNS,
      SUM(ingested_commission_am) AS revenue
      FROM "PROD_ETL"."ATARI_FORKLIFT"."F_ATARI_CC"
      WHERE DW_EFF_DT >= $target_date_start
      and DW_EFF_DT <= $target_date_end
      AND revenue_tran_in = TRUE
      AND aflt_partner_nm NOT IN ('capital_one_credit_cards')
      GROUP BY 1,2,3,4,5,6
      order by aflt_partner_nm, DW_EFF_DT),

      -- CALCULATE OUTLIER DATES FOR EACH PARTNER PRODUCT
      T2 AS (
      SELECT * FROM (
        SELECT *
          , AVG(REV_TXNS) OVER (PARTITION BY AFLT_PARTNER_NM, MARKETPLACE_PROD_ID, within_outlier_calc_period ) AS AVG_TXNS
          , STDDEV(REV_TXNS) OVER (PARTITION BY AFLT_PARTNER_NM,  MARKETPLACE_PROD_ID, within_outlier_calc_period) AS STDDEV_TXNS
          , CASE
          WHEN DAY IN ('Sat','Sun') THEN FLOOR((AVG_TXNS - 0.4*STDDEV_TXNS)) -- WEEKENDS WILL HAVE A LOWER TXNS THRESHOLD THAN WEEKDAYS (2 STDDEVS VS 1 STDDEV)
          ELSE FLOOR((AVG_TXNS - 0.1*STDDEV_TXNS))
          END AS THRESHOLD
          , CASE
          WHEN REV_TXNS < THRESHOLD THEN 1
          ELSE 0
          END AS OUTLIER
        FROM T1
        order by aflt_partner_nm, DW_EFF_DT
        )
        WHERE THRESHOLD IS NOT NULL
      ),

      --LAST COMPLETE DAY OF DATA FOR EACH PARTNER PRODUCT
      -- We search for the maximum non-outlier date
      LAST_COMPLETE_DATE_0 AS (
      SELECT DISTINCT AFLT_PARTNER_NM
      , MARKETPLACE_PROD_ID
      , MIN(DW_EFF_DT) OVER (PARTITION BY AFLT_PARTNER_NM, MARKETPLACE_PROD_ID) AS FIRST_COMPLETE_DAY
      , MAX(DW_EFF_DT) OVER (PARTITION BY AFLT_PARTNER_NM, MARKETPLACE_PROD_ID) AS LAST_COMPLETE_DAY
      FROM T2
      WHERE OUTLIER = 0
      -- and THRESHOLD is not null
      AND MARKETPLACE_PROD_ID IS NOT NULL
      ),
      
      LAST_COMPLETE_DATE AS (
        select * 
        from (
          select *
            , row_number() over (partition by marketplace_prod_id order by last_complete_day desc) as rn
          from LAST_COMPLETE_DATE_0
            ) lcd 
         where lcd.rn=1
        order by marketplace_prod_id
        ),
        
SERP_RANK AS (
SELECT DISTINCT DW_EFF_DT
      ,SUM(SERP_IMPRESSION_CT) as impressions 
      , SUM(SERP_CLICK_CT) as clicks 
      , SUM(SERP_RANK * SERP_IMPRESSION_CT) / SUM(SERP_IMPRESSION_CT) as weighted_avg_rank 
FROM SEO_MART.PROD.ORGANIC_GROWTH_DRILLDOWN 
WHERE DW_EFF_DT >= current_date() - 700
 AND PAGE_PATH_TX = 'best/credit-cards/airline'
 AND SERP_IMPRESSION_CT >0
group by 1
)
        
SELECT CCONV.*
    , SERP_RANK.weighted_avg_rank
    , LCD.LAST_COMPLETE_DAY
    , row_number() over (partition by URL_PATH_TX, DEVICE_TYPE_NM, SECTION_NM, PRODUCT_ID, MARKETPLACE_OFFER_ID ORDER BY CLICK_DATE ASC) AS cconv_recency_weight
  FROM CCONV
  LEFT JOIN LAST_COMPLETE_DATE LCD 
    ON CCONV.PRODUCT_ID = LCD.MARKETPLACE_PROD_ID
  LEFT JOIN SERP_RANK 
    ON CCONV.CLICK_DATE = SERP_RANK.DW_EFF_DT
  WHERE CCONV.CLICK_DATE < (LCD.LAST_COMPLETE_DAY-1)
ORDER BY 1 DESC

